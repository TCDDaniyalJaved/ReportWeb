        --bs-table-active-color: #646e78;
        --bs-table-active-bg: rgba(255, 106, 0, 0.08);
        --bs-table-hover-color: var(--bs-body-color);
        --bs-table-hover-bg: rgba(34, 48, 62, 0.06);
        width: 100%;
       /*  margin-bottom: 1rem; */
        vertical-align: middle;
        border-color: var(--bs-table-border-color);
    }

        .table2 > :not(caption) > * > * {
            padding: 0.502rem 0.4rem;
            padding-right: 30px;
            padding-left: 24px;
           /*  padding: 0.1rem 0.4rem; */
            background-color: var(--bs-table-bg);
            border-bottom-width: var(--bs-border-width);
            box-shadow: inset 0 0 0 9999px var(--bs-table-bg-state, var(--bs-table-bg-type, var(--bs-table-accent-bg)));
        }
    .cGroup2 {
        background-color: #ff6666;
        color:white;
        font-weight: 800; /*background-color: #e22f3e;*/
    }

    .cGroupT {
        /*background-color: #ddd;*/
        color: #000;
        /* color: #3276b1; */
        font-weight: 600; /*background-color: #e22f3e;*/
    }

    .cGroupGT {
        color: #000;
       /*  color: #3276b1; */
        font-size: 1.2rem;
        font-weight: 800;
    }

    .table2 > tbody {
        vertical-align: inherit;

    }

    .table2 > thead {
        vertical-align: bottom;
        position: sticky;
     
    }
    .cDetail {
        color: var(--bs-table-color-state, var(--bs-table-color-type, var(--bs-table-color)));
        font-weight: 500;
 }
    table th{
      font-weight:800;
        color: #000;
    }
/*    #number{
     text-align:right;
   } */
/*     .card-datatable {
        max-height: 420px;
        overflow-y: auto;
    } */
    .Amountright {
        text-align: right;
    }

    .card-title{
      font-weight:800;
    }
    .userTable_filter{
      display:none;
    }

    .table-header {
      border-top:2px solid #000;
      border-bottom:1px solid #000;
    }
