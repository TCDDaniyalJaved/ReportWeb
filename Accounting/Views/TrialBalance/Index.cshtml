
@{
    ViewData["Title"] = "Trail Balance";
}
@{
    Layout = "_HorizontalLayout";
}

@section VendorStyles {
    @await Html.PartialAsync("_VendorStyles")
}

@section VendorScripts {
    @await Html.PartialAsync("_VendorScripts")
}

@section PageScripts {
    <script src="~/js/advanced.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
<style>
    .MiniHeading {
        font-size: 12px;
        color: black;
        font-weight: 700;
        margin-bottom: 0;
    }

    td{
      padding-left:0;
    }
    th {
        font-size: 15px;
    }
   footer{
     display:none;
   }

      .cGroup {
 /*        background-color: var(--bs-table-border-color); */
      /*   color: #3276b1; */
        color: #000;
         font-weight:bold;
        padding-left: 0;
      
        margin-left:0;/*background-color: #e22f3e;*/
    }
    .table2 {
        --bs-table-color-type: initial;
        --bs-table-bg-type: initial;
        --bs-table-color-state: initial;
        --bs-table-bg-state: initial;
        --bs-table-color: var(--bs-body-color);
        --bs-table-bg: transparent;
        --bs-table-border-color: #e4e6e8;
        --bs-table-accent-bg: transparent;
        --bs-table-striped-color: var(--bs-body-color);
