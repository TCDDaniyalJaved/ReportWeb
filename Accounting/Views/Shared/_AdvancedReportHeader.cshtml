<style>
    #masterTable {
        table-layout: fixed !important;
        width: 100% !important;
    }

    .dataTables_scrollBody table,
    .dataTables_scrollHeadInner table {
        table-layout: fixed !important;
        width: 100% !important;
    }

    table.dataTable {
        width: 100% !important;
        background-color: var(--bs-table-bg) !important;
    }

    .dataTables_scrollHeadInner,
    .dataTables_scrollBody table {
        width: 100% !important;
    }

    .advanced-dropdown {
        position: absolute;
        top: 110%;
        right: 0;
        width: 760px;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 8px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
        display: flex;
        z-index: 9999;
    }

        .advanced-dropdown .col {
            flex: 1;
            padding: 16px;
        }

            .advanced-dropdown .col:not(:last-child) {
                border-right: 1px solid #eee;
            }

        .advanced-dropdown h6 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
            display: flex;
            gap: 6px;
            align-items: center;
        }

        .advanced-dropdown ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .advanced-dropdown li {
            padding: 6px 0;
            cursor: pointer;
            font-size: 14px;
        }

            .advanced-dropdown li:hover {
                color: #0d6efd;
            }

        .advanced-dropdown .add {
            color: #0d6efd;
            font-weight: 600;
            margin-top: 8px;
        }

    .group-row {
        background-color: var(--bs-table-bg) !important;
        border-left: 4px solid #0d6efd;
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 600;
    }

        .group-row:hover {
            background-color: var(--bs-table-bg) !important;
        }

        .group-row .toggle-icon {
            font-weight: bold;
            margin-right: 8px;
            transition: transform 0.2s;
            display: inline-block;
        }

        .group-row.collapsed .toggle-icon {
            transform: rotate(-90deg);
        }

    .group-item.active {
        background-color: #e7f1ff;
        color: #0d6efd;
        font-weight: 600;
        border-radius: 20px
    }

    .group-item {
        transition: all 0.15s;
    }

    .filter-item.active {
        background-color: #e7f1ff;
        color: #0d6efd;
        font-weight: 600;
        border-radius: 20px
    }

    .filter-item {
        transition: all 0.15s;
    }

    .group-header-content {
        display: flex;
        align-items: center;
        gap: 6px;
        max-width: 100%;
    }

        .group-header-content .group-text {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    #searchContainer {
        gap: 4px; /* Space between badges and input */
        padding: 4px 8px; /* Inner padding */
        flex-wrap: nowrap; /* Default: no wrap, but switch to wrap on small screens if needed */
        overflow-x: auto; /* Scroll horizontally if too many badges */
        scrollbar-width: none; /* Hide scrollbar for cleaner look */
    }

        #searchContainer::-webkit-scrollbar {
            display: none; /* Hide scrollbar in WebKit */
        }

    .badge-tag {
        display: inline-flex;
        align-items: center;
        background-color: #e7f1ff;
        color: #0d6efd;
        border-radius: 20px;
        padding: 2px 8px;
        font-size: 0.85rem;
        margin: 2px 0;
        white-space: nowrap;
    }

        .badge-tag .remove-btn {
            margin-left: 6px;
            cursor: pointer;
            font-weight: bold;
            color: #6c757d;
        }

            .badge-tag .remove-btn:hover {
                color: #dc3545;
            }

    /* Responsive: On small screens, allow wrapping */
    @@media (max-width: 768px) {
        #searchContainer {
            flex-wrap: wrap;
            height: auto !important; /* Dynamic height */
            min-height: 44px;
        }

        #universalSearch {
            order: 999; /* Input last in wrap mode */
            width: 100% !important;
        }
    }

    .badge-tag svg {
        fill: #6c757d;
    }

    .badge-tag .filter-icon:hover svg {
        fill: #0d6efd;
    }
</style>

<div class="input-group" style="width: 100%; max-width: 560px; position:relative;">
    <span class="input-group-text border-end-0">
        <i class="bx bx-search text-muted"></i>
    </span>
    <div class="d-flex flex-wrap align-items-center form-control border-start-0 border-end-0 p-0"
         id="searchContainer"
         style="min-height: 44px; padding: 6px 8px; gap: 6px; overflow: visible;">
        <input type="search"
               id="universalSearch"
               class="border-0 flex-grow-1"
               placeholder="Search by voucher, date, amount..."
               style="height: 32px; min-width: 120px; outline: none; background: transparent;">
    </div>
    <span class="input-group-text border-start-0" id="searchFilterToggle" style="cursor:pointer;">
        <i class="bx bx-filter-alt text-muted"></i>
    </span>

    <!-- Advanced Dropdown -->
    <div id="advancedDropdown" class="advanced-dropdown d-none">
        <div class="col">
            <h6><i class="bx bx-filter"></i> Filters</h6>
            <ul id="filterList">
                <!-- This is dynamically JS based config -->
            </ul>
        </div>
        <div class="col">
            <h6><i class="bx bx-grid-alt"></i> Group By</h6>
            <ul id="groupByList">
                <!-- This is dynamically JS based config -->
            </ul>
        </div>
        <div class="col">
            <h6><i class="bx bx-star"></i> Favorites</h6>
            <ul><li>Save current search</li></ul>
        </div>
    </div>
</div>

<!-- Filter Modal -->
<div class="modal fade" id="filterModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="filterModalTitle">Select Filter</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="filterModalBody">
                <!-- Filter options will be dynamically appended here as per configuration -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="applyFilterBtn">Apply</button>
            </div>
        </div>
    </div>
</div>