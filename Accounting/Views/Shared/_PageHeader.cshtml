@model Accounting.Models.PageHeaderVM

<ebit-section class="d-flex justify-content-between align-items-center pb-3 flex-wrap create-header w-100 px-5 pt-3">
    <ebit-section class="d-flex align-items-center justify-content-between flex-wrap w-100">

        <!-- Left -->
        <ebit-section class="d-flex align-items-center gap-3">
            <button type="button" class="btn btn-primary" id="btnCreate">
                @Model.NewButtonText
            </button>

            <h5 class="mb-0 fw-semibold d-flex align-items-center gap-2">
                @Model.Title
                <i class="bx bx-cog ms-1 text-muted" style="cursor:pointer;"></i>
            </h5>
        </ebit-section>

        <!-- Search -->
        <ebit-section class="flex-grow-1 d-flex justify-content-center px-4">
            <ebit-section class="input-group" style="max-width:560px;">
                <span class="input-group-text  border-end-0">
                    <i class="bx bx-search text-muted"></i>
                </span>
                <input type="search" id="universalSearch"
                       class="form-control border-start-0"
                       placeholder="@Model.SearchPlaceholder">
            </ebit-section>
        </ebit-section>

        <!-- Pagination -->
        <ebit-section class="d-flex align-items-center gap-3">

            <ebit-section id="customPagination" class="d-none d-flex align-items-center gap-2">
                <button variant="ghost" class="btn btn-sm btn-outline-primary rounded" id="prevPage">
                    <i class="bx bx-chevron-left"></i>
                </button>
                <span id="pageInfo" class="fw-medium text-primary px-2">1 / 2</span>
                <button variant="ghost" class="btn btn-sm btn-outline-primary rounded" id="nextPage">
                    <i class="bx bx-chevron-right"></i>
                </button>
            </ebit-section>

            <select id="sharedLength" class="form-select form-select-sm" style="width: auto;">
                <option value="7" selected>7 Records Per Page</option>
                <option value="10">10 Records Per Page</option>
                <option value="25">25 Records Per Page</option>
                <option value="50">50 Records Per Page</option>
                <option value="100">100 Records Per Page</option>
                <option value="-1">All Records</option>
            </select>

        </ebit-section>
    </ebit-section>
</ebit-section>
