<div class="wizard-step " id="step3">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title mb-0 pb-0">Asset Template</h3>
        </div>
        <div class="card-datatable table-responsive pb-0">

            <table id="assetTable" class="table">
                <thead class="border-top">
                    <tr>
                        <th><input type="checkbox" id="selectAll"></th>
                        <th></th>
                        <th hidden>Id</th>
                        <th>Asset Template</th>
                        <th>Description</th>
                        <th>Active</th>
                        <th></th>
                    </tr>
                </thead>
            </table>

        </div>
    </div>
</div>


