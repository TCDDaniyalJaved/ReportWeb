@* Views/Chart/Report.cshtml *@
@model List<Accounting.Models.Chart> // Adjust namespace/model as per your project

@{
    ViewData["Title"] = "Chart of Accounts Report";
}

@section VendorStyles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="~/css/report.css" rel="stylesheet" />
}

@section VendorScripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.5.23/dist/jspdf.plugin.autotable.min.js"></script>
}

<div class="container">
    <div class="report-header">
        <h2>Chart of Accounts Report</h2>
        <p>Generated on: @DateTime.Now.ToString("f")</p>
        @if (ViewBag.CompanyName != null)
        {
            <p>Company: @ViewBag.CompanyName</p>
        }
        @if (ViewBag.GroupName != null)
        {
            <p>Group: @ViewBag.GroupName</p>
        }
    </div>
    <div class="export-buttons">
        <button class="btn btn-primary me-2" onclick="exportToPDF()">Export to PDF</button>
        <button class="btn btn-success me-2" onclick="exportToExcel()">Export to Excel</button>
        <a href="@Url.Action("Index", "Chart")" class="btn btn-secondary back-button">Back to List</a>
    </div>
    <table class="report-table table table-bordered">
        <thead>
            <tr>
                <th>Code</th>
                <th>Account Description</th>
                <th>Nature</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@item.NatureId</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section PageScripts {
    <script>
        function exportToExcel() {
            const data = @Html.Raw(Json.Serialize(Model.Select(x => new { x.Code, x.Name, x.NatureId })));
            const excelData = [['Code', 'Account Description', 'Nature']];
            data.forEach(row => {
                excelData.push([row.Code || '', row.Name || '', row.NatureName || '']);
            });
            const worksheet = XLSX.utils.aoa_to_sheet(excelData);
            const workbook = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(workbook, worksheet, 'Chart of Accounts');
            XLSX.writeFile(workbook, 'Chart_of_Accounts_Report.xlsx');
        }

        function exportToPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text('Chart of Accounts Report', 14, 20);
            doc.text(`Generated on: @DateTime.Now.ToString("f")`, 14, 30);
            @if (ViewBag.CompanyName != null)
            {
                <text>doc.text('Company: @ViewBag.CompanyName', 14, 40);</text>
            }
            @if (ViewBag.GroupName != null)
            {
                <text>doc.text('Group: @ViewBag.GroupName', 14, @ViewBag.CompanyName != null ? 50 : 40);</text>
            }
            doc.autoTable({
                startY: @(ViewBag.GroupName != null ? 60 : ViewBag.CompanyName != null ? 50 : 40),
                head: [['Code', 'Account Description', 'Nature']],
			 body: @Html.Raw(Json.Serialize(Model.Select(x => new[] { x.Code ?? "", x.Name ?? "", x.NatureId.ToString() }))),

                theme: 'grid',
                styles: { fontSize: 10 },
                headStyles: { fillColor: [200, 200, 200] }
            });
            doc.save('Chart_of_Accounts_Report.pdf');
        }
    </script>
}
