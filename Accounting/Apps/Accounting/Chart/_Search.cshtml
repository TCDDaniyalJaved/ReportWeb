@model Accounting.Models.Chart
<script src="~/js/forms-selects.dist.js"></script>

<div class="offcanvas offcanvas-end" id="filterOffcanvas" tabindex="-1" aria-labelledby="filterOffcanvasLabel">
    <div class="offcanvas-header border-bottom py-4 d-flex justify-content-between">
        <div class="d-flex flex-column">
            <h6 class="mb-1" id="filterOffcanvasLabel">Filter Options</h6>
            <p class="mb-0 small">Customize your search filters</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="mt-4">
                <button class="btn btn-primary" onclick="updateFilter()">Update</button>
            </div>
            <a href="javascript:void(0)" class="text-heading" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Reset Filters" onclick="resetFilters()">
                <i class="bx bx-refresh bx-24px"></i>
            </a>
            <a href="javascript:void(0)" class="text-heading" data-bs-dismiss="offcanvas" aria-label="Close">
                <i class="bx bx-x bx-lg"></i>
            </a>
        </div>
    </div>
    <div class="offcanvas-body pt-4">
        <div class="template-customizer-filters">
            <h5 class="mb-4">
                <span class="bg-label-primary rounded-1 py-1 px-3 small">Filters</span>
            </h5>
            <div class="w-100">
                <label for="CompanyId" class="form-label d-block mb-2 mt-4">Company</label>
                <select asp-for="CompanyId" asp-items="@ViewBag.CompanyId" class="select2 form-select" multiple id="FilterCompanyId">
                    <option value="0">Select Company</option>
                </select>
                <label for="NewUser_GroupId" class="form-label d-block mb-2 mt-4">Group</label>
                <select asp-for="GroupId" asp-items="@ViewBag.GroupId" class="select2 form-select" multiple id="FilterGroupId">
                    <option value="0">Select Group</option>
                </select>
            </div>
        </div>
    </div>
</div>
