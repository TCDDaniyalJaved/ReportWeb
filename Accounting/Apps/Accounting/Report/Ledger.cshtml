@{
    ViewData["Title"] = "Ledger";
}

@section VendorStyles {
    @await Html.PartialAsync("_VendorStyles")
}

@section VendorScripts {
    @await Html.PartialAsync("_VendorScripts")
}
<!-- CSS first -->
<link href="~/accounting/css/advancedropdown.css" rel="stylesheet" />
<!-- Your custom scripts -->
<script src="~/Accounting/js/advancedropdown.js"></script>

<!-- Optional: module scripts -->
@section PageScripts {
    <script type="module" src="~/Accounting/js/Ledger.js"></script>
    <script type="module" src="~/Accounting/js/dropdawn.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        //       document.addEventListener('DOMContentLoaded', function () {
        //     flatpickr("#dateRange", {
        //         mode: "range",         // Select start and end date
        //         dateFormat: "d/m/Y",   // Format as per aapko
        //         allowInput: true,
        //         defaultDate: null
        //     });
        // });
                $(function () {
            // Check if element exists
            var bsRangePickerDropdown = $('#bs-rangepicker-dropdown');

            if (bsRangePickerDropdown.length) {
                bsRangePickerDropdown.daterangepicker({
                    showDropdowns: true,           // month/year dropdowns
                    autoUpdateInput: false,        // prevent auto fill until user selects
                    opens: 'right',
                    locale: {
                        format: 'YYYY-MM-DD',      // aap apne hisaab se date format set kar sakte ho
                        cancelLabel: 'Clear'
                    }
                });

                // Update input on apply
                bsRangePickerDropdown.on('apply.daterangepicker', function(ev, picker) {
                    $(this).val(picker.startDate.format('YYYY-MM-DD') + ' to ' + picker.endDate.format('YYYY-MM-DD'));
                });

                // Clear input on cancel
                bsRangePickerDropdown.on('cancel.daterangepicker', function(ev, picker) {
                    $(this).val('');
                });
            }
        });
    </script>
}


<ebit-section p="0" m="0">
    <div id="wizardStepper" class="bs-stepper wizard-numbered" style="box-shadow:none;">

        <!-- Wizard Header (currently hidden) -->
        <ebit-section class="bs-stepper-header d-none">
            <ebit-section class="step" data-target="#account-details">
                <ebit-button type="button" class="step-trigger"></ebit-button>
            </ebit-section>
            <ebit-section class="line"><i class="bx bx-chevron-right"></i></ebit-section>
            <ebit-section class="step" data-target="#personal-info">
                <ebit-button type="button" class="step-trigger"></ebit-button>
            </ebit-section>
        </ebit-section>

        <!-- Wizard Content -->
        <ebit-section class="bs-stepper-content p-0 m-0">

            <!-- Header + Search bar -->
            <ebit-section class="d-flex justify-content-between align-items-center pb-3 flex-wrap create-header w-100 px-5 pt-3">
                <ebit-section class="d-flex align-items-center w-100" id="pageHeader">
                    <ebit-section class="d-flex align-items-start gap-3" style="flex: 0 0 auto; min-width: 200px;">
                        <div>
                            <h4 class="mb-1 fw-bold d-flex align-items-center gap-2">
                                Ledger
                                <i class="bx bx-cog text-muted" style="cursor:pointer; font-size:1.1rem;"></i>
                            </h4>
                            <h6 class="mb-0 text-muted fw-normal">Accounting</h6>
                            <button id="downloadPdfBtn" class="btn btn-primary mb-3">Download PDF</button>

                        </div>
                    </ebit-section>

                    <ebit-section class="d-flex justify-content-center flex-grow-1">
                        <div class="input-group" style="width: 100%; max-width: 560px; position: relative;">
                            <span class="input-group-text border-end-0">
                                <i class="bx bx-search text-muted"></i>
                            </span>
                            <div class="d-flex flex-wrap align-items-center form-control border-start-0 border-end-0 p-0"
                                 id="searchContainer"
                                 style="min-height: 44px; padding: 6px 8px; gap: 6px; overflow: visible;">
                                <!-- Dynamic filter/voucher badges go here -->
                                <input type="search" id="universalSearch" class="border-0 flex-grow-1"
                                       placeholder="Search by voucher, date, amount..."
                                       style="height: 32px; min-width: 120px; outline: none; background: transparent;">
                            </div>
                            <span class="input-group-text border-start-0" id="searchFilterToggle" style="cursor:pointer;">
                                <i class="bx bx-filter-alt text-muted"></i>
                            </span>

                            <div id="advancedDropdown" class="advanced-dropdown d-none" style="right:0; background-color:var(--bs-body-bg)">
                                <div class="col">
                                    <h6><i class="bx bx-filter"></i> Filters</h6>
                                    <ul id="filterList">
                                    </ul>
                                </div>
                                <div class="col">
                                    <h6><i class="bx bx-grid-alt"></i> Group By</h6>
                                    <ul id="groupByList">
                                    </ul>
                                </div>
                                <div class="col" id="favorites">
                                    <h6><i class="bx bx-star"></i> Favorites</h6>
                                    <ul>
                                        <li id="saveFavorite">Save current search</li>
                                    </ul>
                                    <ul id="favoritesList"></ul>
                                </div>
                            </div>
                        </div>
                    </ebit-section>

                    <div style="flex: 0 0 auto; min-width: 200px;"></div>
                </ebit-section>
            </ebit-section>

            <!-- Main Table Content -->
            <ebit-section id="account-details" class="content">
                <ebit-section id="innerWizard" class="wizard">
                    <ebit-section class="wizard-content p-0 m-0">
                        <ebit-section id="inner-step1" class="wizard-step p-0 m-0">
                            <ebit-table id="masterTable" class="table mt-0 pt-0">

                                <!-- Table Header -->
                                <ebit-head class="border-top" style="background-color:var(--bs-table-bg)!important;">
                                    <ebit-row>
                                        <ebit-headcolumn datafield="Date" header="Date" width="15%"></ebit-headcolumn>
                                        <ebit-headcolumn datafield="VoucherNo" header="Voucher #" width="15%"></ebit-headcolumn>

                                        <ebit-headcolumn datafield="OppName" header="Account Name / Description" width="15%"></ebit-headcolumn>
                                        <ebit-headcolumn datafield="Debit" isamount="true" group-total="true" header="Debit / Receipt" width="15%"></ebit-headcolumn>
                                        <ebit-headcolumn datafield="Credit" isamount="true" group-total="true" header="Credit / Payment" width="15%"></ebit-headcolumn>
                                        <ebit-headcolumn datafield="Credit" header="Activity" width="15%"></ebit-headcolumn>
                                    </ebit-row>
                                </ebit-head>

                                <!-- Table Body will be populated dynamically -->
                                <!-- Table Footer -->
                                <ebit-footer>
                                    <ebit-row>
                                        <ebit-bodycolumn colspan="2">
                                            Total Records : <span id="totalRecords">0</span>
                                        </ebit-bodycolumn>
                                    </ebit-row>
                                    <ebit-row>
                                        <ebit-bodycolumn colspan="2">
                                            <button id="loadMoreBtn" class="btn bg-transparent" style="display:none;">
                                                Load More
                                                <span class="spinner-border spinner-border-sm d-none" id="loadMoreSpinner"></span>
                                            </button>
                                        </ebit-bodycolumn>
                                    </ebit-row>
                                </ebit-footer>

                            </ebit-table>
                        </ebit-section>
                    </ebit-section>
                </ebit-section>
            </ebit-section>

            <!-- Secondary / Detail view area -->
            <ebit-section id="personal-info" class="content p-0 px-5"></ebit-section>

        </ebit-section>
    </div>

    <!-- ── Modals ── -->
    <!-- Save Favorite Modal -->
    <div class="modal fade" id="saveFavoriteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Save Current View as Favorite</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label for="favoriteName" class="form-label">Favorite Name</label>
                    <input type="text" id="favoriteName" class="form-control" placeholder="Enter favorite name">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="saveFavoriteConfirm" class="btn btn-primary">Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Modal -->
    <div class="modal fade" id="filterModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="filterModalTitle">Select Filter</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="filter-LedgerName" class="filter-option mb-3">
                        <select class="form-select select2"
                                data-url="/Dropdawn/UserWiseAccount"
                                data-placeholder="Select Ledger..."
                                name="Account"></select>
                    </div>
                    <div class="filter-option mb-3" id="filter-groupName">
                        <select class="form-select select2"
                                data-url="/Dropdawn/Groupid"
                                data-placeholder="Select Group..."
                                name="GroupName"></select>
                    </div>
                    <div class="filter-option mb-3" id="filter-date">
                        @* <input type="text" id="dateRange" class="form-control" /> *@
                        <input type="text" id="bs-rangepicker-dropdown" class="form-control" placeholder="Select date range">
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="applyFilterBtn">Apply</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Modal - Dynamic Version -->
