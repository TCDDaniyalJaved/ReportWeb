@{
    /* Page Layout */
    Layout = "_HorizontalLayout";
}

@section VendorStyles {
    @await Html.PartialAsync("_VendorStyles")
}

@section VendorScripts {
    @await Html.PartialAsync("_VendorScripts")
}
@section PageScripts {
    <script type="module" src="/Accounting/js/dummy.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

<div class="container mt-5">
        <h2>Trial Balance Report</h2>
        <table id="trialBalanceTable" class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Account Name</th>
                    <th>Total Debit</th>
                    <th>Total Credit</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

   
