@{
    ViewData["Title"] = "Dashboard - Analytics";
}

@section VendorStyles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.dist.css" />
}

@section VendorScripts {
    <script src="~/vendor/libs/apex-charts/apexcharts.dist.js"></script>
    <script src="~/Accounting/js/chart-helper.js"></script>
}

<div class="container-fluid px-4 py-5">
    <h4 class="mb-4 text-center fw-bold">Financial Analytics Dashboard</h4>

    <div class="row g-4">
        <!-- Ledger-wise debit & credit main chart -->
       @*  <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Ledger-wise Debit & Credit</h5>
                </div>
                <div class="card-body">
                    <div id="weeklyExpenseRadial" style="height: 420px;"></div>
                </div>
            </div>
        </div> *@
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Ledger-wise Debit & Credit</h5>
                </div>
                <div class="card-body">
                    <div id="RevenueChart" style="height: 420px;"></div>
                </div>
            </div>
        </div>
        <!-- Current month overview donut -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Current Month Overview</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <div id="orderStatisticsChart" style="height: 220px; width: 220px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Duplicate Ledger-wise chart for comparison -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Ledger-wise Debit & Credit</h5>
                </div>
                <div class="card-body">
                    <div id="ledgerChart1" style="height: 420px;"></div>
                </div>
            </div>
        </div>

        <!-- Duplicate current month overview donut -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Current Month Overview</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <div id="orderStatisticsChart1" style="height: 220px; width: 220px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Company-wise summary horizontal chart -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Company-wise Summary</h5>
                </div>
                <div class="card-body">
                    <div id="companyChart" style="height: 420px;"></div>
                </div>
            </div>
        </div>

        <!-- Voucher type distribution stacked chart -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Voucher Type Distribution</h5>
                </div>
                <div class="card-body">
                    <div id="voucherChart" style="height: 420px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Account-wise summary pie chart -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Account-wise Summary</h5>
                </div>
                <div class="card-body">
                    <div id="companyChart1" style="height: 420px;"></div>
                </div>
            </div>
        </div>

        <!-- Month-wise debit pie chart -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Month Wise Debit</h5>
                </div>
                <div class="card-body">
                    <div id="monthpiechart" style="height: 420px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Monthly debit & credit trend chart -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Monthly Debit & Credit Trend</h5>
                </div>
                <div class="card-body">
                    <div id="monthlyTrendChart" style="height: 380px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<table class="table table-borderless">
    <thead>
        <tr>
            <th>No</th>
            <th>Browser</th>
            <th>Visits</th>
            <th class="w-50">Data In Percentage</th>
        </tr>
    </thead>
    <tbody id="browserStatsBody">
        <!-- JS se rows aayengi -->
    </tbody>
</table>


@section PageScripts {
    <script src="~/Accounting/js/dashboards-analytics-graph.js"></script>
}
